# ふりぃらじかるず フロントエンド 環境変数の雛形
# 秘匿値は含めない（セキュリティ規定）。値は用途の説明のみ。

# API クライアントのモード切替シーム。
#   true（既定） … モックデータで動く（バックエンド未完成時・ローカル開発）
#   false        … 実 API（NEXT_PUBLIC_API_BASE）と通信する
NEXT_PUBLIC_USE_MOCK=true

# 実 API のベース URL（NEXT_PUBLIC_USE_MOCK=false のとき使用）。既定は "/api"。
# 例: http://127.0.0.1:8000/api
NEXT_PUBLIC_API_BASE=

# ----- 認証（Google Identity Services） -----
# 認証モード表示用（バックエンドの AUTH_MODE と揃える）。
NEXT_PUBLIC_AUTH_MODE=mock
# Google のクライアントID（秘匿値ではない）。設定すると /login に GIS ボタンが表示される。
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

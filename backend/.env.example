# ==============================================================================
# ふりぃらじかるず Backend — 環境変数の雛形
#
# このファイルを backend/.env にコピーして秘匿値を埋めてください。
#   cp backend/.env.example backend/.env
# .env は絶対にコミットしないこと（.gitignore で除外済み・セキュリティ規定）。
# 秘匿値（キー・パスワード）はこの雛形では空にしています。
# ==============================================================================

# ------------------------------------------------------------------------------
# データベース切替シーム
#   DB_BACKEND で接続先を切り替える。app/config.py が値に応じて接続URLを解決する。
#   - sqlite     … ローカル開発の既定（外部DB不要・SQLITE_PATH を使用）
#   - mysql      … Azure Database for MySQL（本番／検証。要 DB_* と SSL 設定）
#   - postgresql … 将来切替用（設計 v3 のPostgreSQL移行に備えた受け口）
# ------------------------------------------------------------------------------
DB_BACKEND=sqlite

# ----- SQLite（DB_BACKEND=sqlite のとき使用） -----
# 相対パスは backend/ を基準に解決される。
SQLITE_PATH=./freeradicals.db

# ----- MySQL（DB_BACKEND=mysql のとき使用・Azure Database for MySQL） -----
DB_HOST=mysql-gen12-class3.mysql.database.azure.com
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=3306
# Azure MySQL は TLS 必須。通常は false（SSLを無効化しない）のままにする。
DB_SSL_DISABLED=false
# サーバ証明書（CA）ファイルのパス。空なら OS 既定のCAバンドルで検証する。
DB_SSL_CA=

# ----- PostgreSQL（DB_BACKEND=postgresql のとき使用・将来用） -----
# 切替時は requirements.txt に psycopg ドライバの追加が必要。
PG_HOST=
PG_USER=
PG_PASSWORD=
PG_NAME=
PG_PORT=5432
PG_SSLMODE=require

# ------------------------------------------------------------------------------
# Azure OpenAI Service（PoC の .env.example のキー名を踏襲。値は空）
# ------------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small

# ------------------------------------------------------------------------------
# Azure AI Search（PoC の .env.example のキー名を踏襲。値は空）
# ------------------------------------------------------------------------------
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=freeradicals-docs-v1

# ------------------------------------------------------------------------------
# KRE（関連知識検索エンジン）切替
#   true のとき本体はスタブ実装を注入し、AI Search / AOAI 未接続でも起動できる。
#   本実装（AzureRetrievalEngine）はロトムが KRE 側で実装する。
# ------------------------------------------------------------------------------
USE_KRE_STUB=true

# ------------------------------------------------------------------------------
# 認証シーム
#   AUTH_MODE … mock（既定・開発/テスト。テナント/ID/PW フォーム）/ google（GIS で Google 認証）。
#   GOOGLE_CLIENT_ID … Google のクライアントID（aud 検証用・秘匿値ではない）。
#     google モードでは必須。GCP プロジェクト food-supply-502014 で作成中（統括が設定）。
# ------------------------------------------------------------------------------
AUTH_MODE=mock
GOOGLE_CLIENT_ID=

# ------------------------------------------------------------------------------
# CORS（カンマ区切りで複数指定可。フロントの配信元を許可する）
# ------------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# ------------------------------------------------------------------------------
# 観測性・アプリ動作モード
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO
TRACE_ID_HEADER=x-trace-id
APP_ENV=development

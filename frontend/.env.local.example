# ふりぃらじかるず フロントエンド ローカル環境変数の雛形
# このファイルを .env.local にコピーして使う（.env.local はコミットしない）。
#   cp .env.local.example .env.local
# 秘匿値は含めない（セキュリティ規定）。

# API クライアントのモード切替シーム。
#   true  … モックデータで動く（バックエンド不要）
#   false … 実 API（FastAPI・ポリゴン実装）と通信する
NEXT_PUBLIC_USE_MOCK=false

# 実 API のベース URL（NEXT_PUBLIC_USE_MOCK=false のとき必須）。
# バックエンドをローカル起動した場合の例（backend: uvicorn app.main:app --port 8000）。
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000/api

# ----- 認証（Google Identity Services） -----
# 認証モードの表示用（バックエンドの AUTH_MODE と揃える。実際の可否はバックエンドが決める）。
NEXT_PUBLIC_AUTH_MODE=mock
# Google のクライアントID（秘匿値ではない）。設定すると /login に GIS ボタンが表示される。
# GCP プロジェクト food-supply-502014 で作成中（統括が設定）。GIS は「承認済み JavaScript 生成元」に
# 現在のオリジン（例: http://localhost:3000）の登録が必要。
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
